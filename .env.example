# =============================================================================
# STORAGE CONFIGURATION (Required)
# =============================================================================
# Storage backend: "local", "r2", or "minio"
STORAGE_BACKEND=r2

# Cloudflare R2 Configuration
R2_BUCKET=artifacts
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_REGION=auto

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
DATABASE_URL=postgresql://vibe:vibe@db:5432/vibe_context

# =============================================================================
# CELERY / QUEUE CONFIGURATION (Required)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# REPO ANALYSIS CONFIGURATION (Optional)
# =============================================================================
# Analysis mode: "local_only" (default, no LLM) or "local_plus_llm"
ANALYSIS_MODE=local_only

# LLM Provider: "none" (default), "gemini", or "openai"
LLM_PROVIDER=none

# Gemini API Key (only needed if LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Key (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key

# =============================================================================
# WEBHOOK CONFIGURATION (Optional)
# =============================================================================
# Outbound webhook notification when context is generated
WEBHOOK_URL=https://your-endpoint.com/webhook
WEBHOOK_SECRET=your_secret_here

# =============================================================================
# TERRAFORM GENERATOR (Optional)
# =============================================================================
# When set, PUT /projects/{id}/revision-decision triggers POST to this service's /process
# with decision, project_id, json_url_r2 (presigned R2 URL), event_id, sent_at
# TERRAFORM_GENERATOR_URL=https://terraform-gen.example.com
# TERRAFORM_GENERATOR_SECRET=your_secret_here

# =============================================================================
# API CONFIGURATION
# =============================================================================
BASE_URL=http://localhost:8000

# =============================================================================
# MISC
# =============================================================================
MIGRATE_ON_STARTUP=1
